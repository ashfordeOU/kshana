CCSDS_TDM_VERS = 2.0
COMMENT Hand-authored CCSDS 503.0-B-2 KVN format example (not real measurements).
COMMENT One two-way X-band pass: a few RANGE (km) and DOPPLER_INTEGRATED (km/s)
COMMENT records, structured per the published 503.0-B-2 (June 2020) examples
COMMENT (Figures E-7/E-8). Values are illustrative format fillers only.
CREATION_DATE = 2026-06-14T00:00:00.000
ORIGINATOR = KSHANA
META_START
TIME_SYSTEM = UTC
START_TIME = 2026-06-14T01:00:00.000
STOP_TIME = 2026-06-14T01:00:20.000
PARTICIPANT_1 = DSS-25
PARTICIPANT_2 = SPACECRAFT
MODE = SEQUENTIAL
PATH = 1,2,1
TRANSMIT_BAND = X
RECEIVE_BAND = X
TURNAROUND_NUMERATOR = 880
TURNAROUND_DENOMINATOR = 749
INTEGRATION_INTERVAL = 10.0
INTEGRATION_REF = MIDDLE
RANGE_UNITS = km
DATA_QUALITY = VALIDATED
META_STOP
DATA_START
RANGE              = 2026-06-14T01:00:00.000   1.23456789012345E+08
DOPPLER_INTEGRATED = 2026-06-14T01:00:00.000          -1.234567890
RANGE              = 2026-06-14T01:00:10.000   1.23456800000000E+08
DOPPLER_INTEGRATED = 2026-06-14T01:00:10.000          -1.230000000
RANGE              = 2026-06-14T01:00:20.000   1.23456810000000E+08
DOPPLER_INTEGRATED = 2026-06-14T01:00:20.000          -1.225000000
DATA_STOP
