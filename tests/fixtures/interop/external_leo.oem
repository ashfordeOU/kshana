CCSDS_OEM_VERS = 2.0
COMMENT  Hand-authored CCSDS 502.0-B-2 KVN example (not real tracking data).
COMMENT  An illustrative LEO arc in the style GMAT / Orekit / STK export, used to
COMMENT  exercise the Kshana OEM *importer* against external flight-dynamics output:
COMMENT  it carries extra metadata keywords (USEABLE_*, INTERPOLATION*), COMMENT
COMMENT  lines, and a COVARIANCE block the importer must skip. Row-0 state is the
COMMENT  classic Vallado r/v example; later rows are illustrative fillers.
CREATION_DATE = 2024-11-04T17:22:31.000000
ORIGINATOR = EXTERNAL-FDS

META_START
OBJECT_NAME = EXAMPLESAT
OBJECT_ID = 2024-001A
CENTER_NAME = EARTH
REF_FRAME = EME2000
TIME_SYSTEM = UTC
START_TIME = 2024-01-01T00:00:00.000000
USEABLE_START_TIME = 2024-01-01T00:00:00.000000
USEABLE_STOP_TIME = 2024-01-01T00:30:00.000000
STOP_TIME = 2024-01-01T00:30:00.000000
INTERPOLATION = HERMITE
INTERPOLATION_DEGREE = 7
META_STOP

